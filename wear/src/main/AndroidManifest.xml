<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.type.watch" />

    <!-- Microphone for on-wrist dictation. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Standalone (opt-in) mode reaches the transcription provider directly from the watch. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_dictate_wear"
        android:label="@string/wear_app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault">

        <!-- Wear OS standalone: the watch app works without a phone-side companion installed.
             Tethered transcription is still preferred when a paired phone with Dictate is reachable. -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <!-- On-watch settings / permission / standalone opt-in entry point. -->
        <activity
            android:name=".ui.WearSettingsActivity"
            android:exported="true"
            android:label="@string/wear_app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The Wear keyboard itself (InputMethodService). -->
        <service
            android:name=".ime.WearImeService"
            android:exported="true"
            android:label="@string/wear_ime_label"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

    </application>

</manifest>
