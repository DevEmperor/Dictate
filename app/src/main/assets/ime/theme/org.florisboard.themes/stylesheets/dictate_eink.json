{
  "$schema": "https://schemas.florisboard.org/snygg/v2/stylesheet",
  "@defines": {
    "--primary": "#000000",
    "--primary-variant": "#000000",
    "--ink": "#000000",
    "--paper": "#ffffff",
    "--secondary": "#000000",
    "--secondary-variant": "#000000",
    "--background": "#ffffff",
    "--background-variant": "#ffffff",
    "--surface": "#ffffff",
    "--surface-variant": "#ffffff",
    "--popup-surface": "#ffffff",
    "--focused-popup-surface": "#000000",
    "--drag-marker": "#000000",
    "--spacer-color": "#000000",
    "--one-hand-background": "#ffffff",
    "--one-hand-foreground": "#000000",
    "--incognito-icon-color": "#000000",
    "--on-primary": "#ffffff",
    "--on-background": "#000000",
    "--on-background-disabled": "#9e9e9e",
    "--on-surface": "#000000",
    "--on-surface-variant": "#000000",
    "--shape": "rounded-corner(8dp, 8dp, 8dp, 8dp)",
    "--shape-variant": "rounded-corner(12dp, 12dp, 12dp, 12dp)",
    "--shape-chip": "rounded-corner(50%, 50%, 50%, 50%)"
  },
  "window": {
    "background": "var(--background)",
    "foreground": "var(--on-background)"
  },
  "window[windowmode=`floating`]": {
    "shape": "rounded-corner(5%, 5%, 5%, 5%)"
  },
  "window-move-handle[windowmode=`fixed`]": {
    "background": "var(--surface)",
    "foreground": "var(--ink)",
    "font-size": "24sp",
    "margin": "16dp 0dp",
    "padding": "8dp",
    "shape": "circle()"
  },
  "window-resize-handle": {
    "background": "var(--ink)"
  },
  "window-resize-action[windowmode=`fixed`]": {
    "background": "var(--ink)",
    "foreground": "var(--on-primary)",
    "font-size": "24sp",
    "padding": "8dp",
    "shape": "circle()"
  },
  "window-resize-action[windowmode=`floating`]": {
    "background": "var(--surface)",
    "foreground": "var(--ink)",
    "shape": "circle()"
  },
  "floating-dock-to-fixed-indicator": {
    "background": "var(--ink)"
  },
  "key": {
    "background": "var(--paper)",
    "foreground": "var(--ink)",
    "font-size": "22sp",
    "shape": "var(--shape)",
    "text-max-lines": "1",
    "border-color": "#000000",
    "border-width": "1.5dp"
  },
  "key:pressed": {
    "background": "var(--ink)",
    "foreground": "var(--paper)"
  },
  "key[code=10]": {
    "background": "var(--ink)",
    "foreground": "var(--paper)",
    "border-color": "#000000",
    "border-width": "1.5dp"
  },
  "key[code=10]:pressed": {
    "background": "var(--paper)",
    "foreground": "var(--ink)"
  },
  "key[code=32]": {
    "background": "var(--paper)",
    "foreground": "var(--ink)",
    "font-size": "12sp",
    "text-overflow": "ellipsis",
    "border-color": "#000000",
    "border-width": "1.5dp"
  },
  "key[code=-201,-202,-203]": {
    "font-size": "18sp"
  },
  "key[code=-204,-205]": {
    "font-size": "12sp"
  },
  "key[code=-205]": {
    "text-max-lines": "2"
  },
  "key[code=-11][shiftstate=`caps_lock`]": {
    "foreground": "var(--ink)"
  },
  "key-hint": {
    "background": "var(--surface)",
    "foreground": "var(--on-surface-variant)",
    "font-family": "monospace",
    "font-size": "12sp",
    "padding": "0dp 1dp 1dp 0dp",
    "text-max-lines": "1"
  },
  "key-popup-box": {
    "background": "var(--paper)",
    "foreground": "var(--ink)",
    "font-size": "22sp",
    "shape": "var(--shape)",
    "border-color": "#000000",
    "border-width": "1.5dp"
  },
  "key-popup-element:focus": {
    "background": "var(--ink)",
    "shape": "var(--shape)",
    "foreground": "var(--paper)"
  },
  "key-popup-element[code=-255]": {
    "font-size": "18sp",
    "text-max-lines": "1"
  },
  "key-popup-extended-indicator": {
    "font-size": "16sp"
  },
  "smartbar": {
    "font-size": "18sp"
  },
  "smartbar-shared-actions-toggle": {
    "background": "var(--paper)",
    "foreground": "var(--ink)",
    "margin": "6dp",
    "shape": "circle()",
    "border-color": "#000000",
    "border-width": "1.5dp"
  },
  "smartbar-extended-actions-toggle": {
    "background": "var(--surface)",
    "foreground": "var(--on-surface-variant)",
    "margin": "6dp",
    "shape": "circle()"
  },
  "smartbar-action-key[code=-214]": {
    "background": "var(--ink)",
    "shape": "circle()",
    "margin": "4dp"
  },
  "smartbar-action-key-icon[code=-214]": {
    "foreground": "var(--on-primary)",
    "font-size": "20sp"
  },
  "smartbar-action-key": {
    "background": "var(--surface)",
    "foreground": "var(--on-background)",
    "shape": "var(--shape)"
  },
  "smartbar-action-key:disabled": {
    "foreground": "var(--on-background-disabled)"
  },
  "smartbar-actions-overflow": {
    "margin": "4dp"
  },
  "smartbar-actions-overflow-customize-button": {
    "background": "var(--ink)",
    "foreground": "var(--on-primary)",
    "font-size": "14sp",
    "margin": "0dp 8dp 0dp 0dp",
    "shape": "rounded-corner(24dp, 24dp, 24dp, 24dp)"
  },
  "smartbar-action-tile": {
    "background": "var(--paper)",
    "foreground": "var(--ink)",
    "font-size": "14sp",
    "margin": "4dp",
    "padding": "4dp",
    "shape": "rounded-corner(20%, 20%, 20%, 20%)",
    "text-align": "center",
    "text-max-lines": "2",
    "text-overflow": "ellipsis",
    "border-color": "#000000",
    "border-width": "1.5dp"
  },
  "smartbar-action-tile:disabled": {
    "foreground": "var(--on-background-disabled)"
  },
  "smartbar-action-tile-icon": {
    "font-size": "24sp",
    "margin": "0dp 0dp 0dp 8dp"
  },
  "smartbar-actions-editor": {
    "background": "var(--background)",
    "foreground": "var(--on-background)",
    "shape": "rounded-corner(24dp, 24dp, 0dp, 0dp)"
  },
  "smartbar-actions-editor-header": {
    "background": "var(--surface)",
    "foreground": "var(--on-surface)",
    "font-size": "16sp",
    "text-max-lines": "1",
    "text-overflow": "ellipsis"
  },
  "smartbar-actions-editor-header-button": {
    "margin": "4dp",
    "shape": "circle()"
  },
  "smartbar-actions-editor-subheader": {
    "foreground": "var(--ink)",
    "font-size": "16sp",
    "font-weight": "bold",
    "padding": "12dp 16dp 12dp 8dp",
    "text-max-lines": "1",
    "text-overflow": "ellipsis"
  },
  "smartbar-actions-editor-tile-grid": {
    "margin": "4dp 0dp"
  },
  "smartbar-actions-editor-tile": {
    "margin": "4dp",
    "padding": "8dp",
    "text-align": "center",
    "text-max-lines": "2",
    "text-overflow": "ellipsis"
  },
  "smartbar-actions-editor-tile[code=-999]": {
    "foreground": "var(--on-background-disabled)"
  },
  "smartbar-actions-editor-tile[code=-991]": {
    "foreground": "var(--drag-marker)"
  },
  "smartbar-candidate-word": {
    "background": "var(--surface)",
    "foreground": "var(--on-background)",
    "font-size": "14sp",
    "margin": "4dp",
    "padding": "8dp 0dp",
    "shape": "rectangle()",
    "text-max-lines": "1",
    "text-overflow": "ellipsis"
  },
  "smartbar-candidate-word:pressed": {
    "background": "var(--ink)",
    "foreground": "var(--paper)"
  },
  "smartbar-candidate-word-secondary-text": {
    "font-size": "8sp",
    "margin": "0dp 2dp 0dp 0dp"
  },
  "smartbar-candidate-clip": {
    "background": "var(--surface)",
    "foreground": "var(--on-background)",
    "font-size": "14sp",
    "margin": "4dp",
    "padding": "8dp 0dp",
    "shape": "rounded-corner(8%, 8%, 8%, 8%)",
    "text-max-lines": "1",
    "text-overflow": "ellipsis"
  },
  "smartbar-candidate-clip:pressed": {
    "background": "var(--ink)",
    "foreground": "var(--paper)"
  },
  "smartbar-candidate-clip-icon": {
    "margin": "0dp 0dp 4dp 0dp"
  },
  "smartbar-candidate-spacer": {
    "foreground": "var(--spacer-color)"
  },
  "clipboard-header": {
    "foreground": "var(--on-background)",
    "font-size": "16sp"
  },
  "clipboard-header-button": {
    "margin": "4dp",
    "shape": "circle()"
  },
  "clipboard-header-button:disabled": {
    "foreground": "var(--on-background-disabled)"
  },
  "clipboard-header-text": {
    "text-max-lines": "1",
    "text-overflow": "ellipsis"
  },
  "clipboard-subheader": {
    "font-size": "14sp",
    "margin": "6dp 10dp 6dp 6dp"
  },
  "clipboard-content": {
    "padding": "10dp 0dp"
  },
  "clipboard-filter-row": {
    "background": "var(--background-variant)",
    "foreground": "var(--on-background)",
    "padding": "0dp 0dp 4dp 0dp",
    "shape": "var(--shape-variant)"
  },
  "clipboard-filter-chip": {
    "background": "var(--paper)",
    "foreground": "var(--ink)",
    "margin": "4dp 4dp 0dp 4dp",
    "padding": "8dp 4dp",
    "shape": "var(--shape-chip)",
    "border-color": "#000000",
    "border-width": "1.5dp"
  },
  "clipboard-filter-chip[state=`active`]": {
    "background": "var(--ink)",
    "foreground": "var(--on-primary)"
  },
  "clipboard-filter-chip-text": {
    "margin": "4dp 0dp 0dp 0dp"
  },
  "clipboard-grid": {
    "shape": "var(--shape-variant)"
  },
  "clipboard-item": {
    "background": "var(--paper)",
    "foreground": "var(--ink)",
    "font-size": "14sp",
    "margin": "4dp",
    "shape": "var(--shape-variant)",
    "text-max-lines": "10",
    "text-overflow": "ellipsis",
    "border-color": "#000000",
    "border-width": "1.5dp"
  },
  "clipboard-item[type=`text`]": {
    "padding": "12dp 8dp"
  },
  "clipboard-item-description": {
    "font-size": "12sp",
    "font-style": "italic"
  },
  "clipboard-item-popup": {
    "background": "var(--paper)",
    "foreground": "var(--ink)",
    "font-size": "14sp",
    "margin": "4dp",
    "shape": "var(--shape-variant)",
    "border-color": "#000000",
    "border-width": "1.5dp"
  },
  "clipboard-item-popup[type=`text`]": {
    "padding": "12dp 8dp"
  },
  "clipboard-item-timestamp": {
    "font-size": "11sp",
    "padding": "16dp 8dp"
  },
  "clipboard-item-actions": {
    "background": "var(--paper)",
    "foreground": "var(--ink)",
    "margin": "4dp",
    "shape": "var(--shape-variant)",
    "border-color": "#000000",
    "border-width": "1.5dp"
  },
  "clipboard-item-action": {
    "font-size": "16sp",
    "padding": "12dp"
  },
  "clipboard-item-action-text": {
    "margin": "4dp 0dp 0dp 0dp"
  },
  "clipboard-clear-all-dialog": {
    "background": "var(--surface)",
    "foreground": "var(--on-surface)",
    "shape": "var(--shape-variant)"
  },
  "clipboard-clear-all-dialog-message": {
    "padding": "16dp"
  },
  "clipboard-clear-all-dialog-buttons": {
    "padding": "4dp"
  },
  "clipboard-clear-all-dialog-button": {
    "background": "var(--surface)",
    "foreground": "var(--on-surface)",
    "shape": "var(--shape-variant)"
  },
  "clipboard-history-disabled-title": {
    "font-weight": "bold"
  },
  "clipboard-history-disabled-message": {
    "padding": "0dp 4dp 0dp 8dp"
  },
  "clipboard-history-disabled-button": {
    "background": "var(--ink)",
    "foreground": "var(--on-primary)",
    "shape": "rounded-corner(24dp,24dp,24dp,24dp)"
  },
  "clipboard-history-locked-title": {
    "font-weight": "bold",
    "text-align": "center"
  },
  "clipboard-history-locked-message": {
    "padding": "0dp 4dp 0dp 0dp",
    "text-align": "center"
  },
  "extracted-landscape-input-layout": {
    "background": "var(--background)"
  },
  "extracted-landscape-input-field": {
    "background": "var(--surface)",
    "foreground": "var(--on-background)",
    "font-size": "16sp",
    "shape": "rounded-corner(12dp, 12dp, 12dp, 12dp)",
    "border-color": "var(--secondary)",
    "border-width": "2dp"
  },
  "extracted-landscape-input-action": {
    "background": "var(--ink)",
    "foreground": "var(--on-surface)",
    "shape": "rounded-corner(4dp, 4dp, 4dp, 4dp)"
  },
  "glide-trail": {
    "foreground": "var(--ink)"
  },
  "incognito-mode-indicator": {
    "foreground": "var(--incognito-icon-color)"
  },
  "inline-autofill-chip": {
    "background": "var(--paper)",
    "foreground": "var(--ink)",
    "border-color": "#000000",
    "border-width": "1.5dp"
  },
  "media-emoji-subheader": {
    "font-weight": "bold",
    "margin": "4dp"
  },
  "media-emoji-key": {
    "background": "var(--surface)",
    "foreground": "var(--on-background)",
    "font-size": "22sp",
    "shape": "var(--shape)"
  },
  "media-emoji-key:pressed": {
    "background": "var(--ink)",
    "foreground": "var(--paper)"
  },
  "media-emoji-key-popup-box": {
    "background": "var(--paper)",
    "foreground": "var(--ink)",
    "font-size": "22sp",
    "shape": "var(--shape)",
    "border-color": "#000000",
    "border-width": "1.5dp"
  },
  "media-emoji-key-popup-element:focus": {
    "background": "var(--ink)",
    "shape": "var(--shape)",
    "foreground": "var(--paper)"
  },
  "media-emoji-tab": {
    "foreground": "var(--on-background)"
  },
  "media-emoji-tab:focus": {
    "foreground": "var(--ink)"
  },
  "media-bottom-row-button": {
    "padding": "16dp 0dp",
    "shape": "var(--shape)"
  },
  "media-emoji-key-popup-extended-indicator": {
    "foreground": "inherit"
  },
  "one-handed-panel": {
    "background": "var(--one-hand-background)",
    "foreground": "var(--one-hand-foreground)"
  },
  "one-handed-panel-button": {
    "padding": "8dp",
    "font-size": "24sp",
    "background": "var(--paper)",
    "shape": "circle()",
    "border-color": "#000000",
    "border-width": "1.5dp"
  },
  "subtype-panel": {
    "background": "var(--background)",
    "foreground": "var(--on-background)",
    "shape": "rounded-corner(24dp, 24dp, 0dp, 0dp)"
  },
  "subtype-panel-header": {
    "background": "var(--surface)",
    "foreground": "var(--on-surface)",
    "font-size": "18sp",
    "padding": "12dp",
    "text-align": "center",
    "text-max-lines": "1",
    "text-overflow": "ellipsis"
  },
  "subtype-panel-list-item": {
    "font-size": "16sp",
    "padding": "16dp"
  },
  "subtype-panel-list-item-icon-leading": {
    "font-size": "24sp",
    "padding": "0dp 0dp 16dp 0dp"
  },
  "subtype-panel-list-item-text": {
    "text-max-lines": "1",
    "text-overflow": "ellipsis"
  }
}
